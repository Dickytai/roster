{
  "version": 2,
  "builds": [
    { "src": "api/**/*.ts", "use": "@vercel/node" },
    { "src": "src/**", "use": "static" }
  ],
  "routes": [
    { "src": "/api/generate", "dest": "/api/generate.ts", "methods": ["POST"] },
    { "src": "/api/download/excel", "dest": "/api/download/excel.ts", "methods": ["POST"] },
    { "src": "/api/download/pdf", "dest": "/api/download/pdf.ts", "methods": ["POST"] },
    { "src": "/(.*)", "dest": "/src/$1" }
  ]
}
